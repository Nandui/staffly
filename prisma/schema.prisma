// Staffly — HR & people-management schema (Centrely Suite).
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for the app at runtime; direct/unpooled for migrations.
  // Neon's Vercel integration provides both names automatically.
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// A leisure centre / site. Top-level scoping dimension (one org, many centres).
// Shared across the Centrely Suite.
model Center {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  siteCode     String? // short site code
  address      String?
  contactName  String?
  contactEmail String?
  phone        String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  staff      StaffMember[]
  staffRoles StaffRole[]
}

// ---- Authentication & users (Auth.js / NextAuth, email + password) ----

// App user (managers / admins). The first run creates the first Admin.
model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  image        String?
  passwordHash String?
  role         String   @default("Viewer") // Viewer | Contributor | Reviewer | Assessor | Admin
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([role])
}

// ─── STAFFLY ─────────────────────────────────────────────────────────────────
// HR & people-management module of the Centrely Suite.

model StaffMember {
  id          String      @id @default(cuid())
  centerId    String
  center      Center      @relation(fields: [centerId], references: [id])
  firstName   String
  lastName    String
  email       String
  phone       String      @default("")
  photo       String?
  roleId      String?
  role        StaffRole?  @relation(fields: [roleId], references: [id])
  status      StaffStatus @default(ACTIVE)
  startDate   DateTime
  endDate     DateTime?
  notes       String      @default("")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  absences         AbsenceRecord[]
  performanceNotes PerformanceNote[]
  disciplinary     DisciplinaryRecord[]
  documents        StaffDocument[]
  certifications    CertRecord[]
  trainingRecords   TrainingRecord[]
  moduleCompletions TrainingModuleCompletion[]
  onboarding        OnboardingCompletion[]

  @@index([centerId])
  @@index([status])
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  PROBATION
}

model StaffRole {
  id                 String              @id @default(cuid())
  centerId           String?
  center             Center?             @relation(fields: [centerId], references: [id])
  name               String
  active             Boolean             @default(true)
  requiredCertTypes  CertType[]          @relation("RoleRequiredCerts")
  staff              StaffMember[]
  trainingProgrammes TrainingProgramme[] @relation("ProgrammeRequiredRoles")
  onboardingSteps    OnboardingStep[]
  createdAt          DateTime            @default(now())
}

// ─── ABSENCE ─────────────────────────────────────────────────────────────────

model AbsenceRecord {
  id                      String      @id @default(cuid())
  staffId                 String
  staff                   StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type                    AbsenceType
  startDate               DateTime
  endDate                 DateTime
  daysCount               Int
  reason                  String      @default("")
  certProvided            Boolean     @default(false)
  approvedBy              String
  returnToWorkNote        String      @default("")
  returnToWorkCompletedAt DateTime?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  @@index([staffId])
}

enum AbsenceType {
  SICK_UNCERTIFIED
  SICK_CERTIFIED
  UNAUTHORISED
  ANNUAL_LEAVE
  PARENTAL_LEAVE
  BEREAVEMENT
  OTHER
}

// ─── PERFORMANCE ─────────────────────────────────────────────────────────────

model PerformanceNote {
  id         String                    @id @default(cuid())
  staffId    String
  staff      StaffMember               @relation(fields: [staffId], references: [id], onDelete: Cascade)
  category   PerformanceNoteCategory
  title      String
  body       String
  visibility PerformanceNoteVisibility @default(MANAGER_ONLY)
  createdBy  String
  noteDate   DateTime
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  @@index([staffId])
}

enum PerformanceNoteCategory {
  POSITIVE
  CONCERN
  FORMAL
  OBJECTIVE
  REVIEW
}

enum PerformanceNoteVisibility {
  MANAGER_ONLY
  SHARED_WITH_STAFF
}

// ─── DISCIPLINARY ─────────────────────────────────────────────────────────────

model DisciplinaryRecord {
  id                String             @id @default(cuid())
  staffId           String
  staff             StaffMember        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  stage             DisciplinaryStage
  status            DisciplinaryStatus @default(OPEN)
  meetingDate       DateTime
  incidentDate      DateTime
  reviewDate        DateTime?
  description       String
  outcome           String
  managedBy         String
  witnessPresent    Boolean            @default(false)
  witnessName       String?
  staffAcknowledged Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([staffId])
  @@index([status])
}

enum DisciplinaryStage {
  VERBAL_WARNING
  WRITTEN_WARNING
  FINAL_WRITTEN_WARNING
  SUSPENSION
  DISMISSAL
}

enum DisciplinaryStatus {
  OPEN
  RESOLVED
  APPEALED
}

// ─── DOCUMENTS ───────────────────────────────────────────────────────────────

model StaffDocument {
  id         String           @id @default(cuid())
  staffId    String
  staff      StaffMember      @relation(fields: [staffId], references: [id], onDelete: Cascade)
  category   DocumentCategory
  name       String
  filename   String
  fileUrl    String // Vercel Blob URL — no base64
  fileSizeKb Int
  fileType   String
  expiryDate DateTime?
  notes      String           @default("")
  uploadedBy String
  uploadedAt DateTime         @default(now())

  @@index([staffId])
}

enum DocumentCategory {
  CONTRACT
  GARDA_VETTING
  RIGHT_TO_WORK
  CERT
  DISCIPLINARY
  TRAINING
  OTHER
}

// ─── CERTIFICATIONS ──────────────────────────────────────────────────────────

model CertType {
  id              String       @id @default(cuid())
  name            String
  issuingBody     String
  validityMonths  Int
  description     String       @default("")
  isBuiltIn       Boolean      @default(false)
  active          Boolean      @default(true)
  certRecords     CertRecord[]
  requiredByRoles StaffRole[]  @relation("RoleRequiredCerts")
  createdAt       DateTime     @default(now())
}

model CertRecord {
  id         String      @id @default(cuid())
  staffId    String
  staff      StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  certTypeId String
  certType   CertType    @relation(fields: [certTypeId], references: [id])
  certNumber String      @default("")
  issueDate  DateTime
  expiryDate DateTime
  documentId String?
  notes      String      @default("")
  recordedBy String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  attachments CertAttachment[]

  @@index([staffId])
  @@index([expiryDate])
}

// Photos / scans attached to a certification record (RLSS card, certificate
// images, …). Stored in Vercel Blob — URL only, no base64.
model CertAttachment {
  id           String     @id @default(cuid())
  certRecordId String
  certRecord   CertRecord @relation(fields: [certRecordId], references: [id], onDelete: Cascade)
  fileUrl      String
  filename     String
  fileType     String
  fileSizeKb   Int
  uploadedBy   String
  uploadedAt   DateTime   @default(now())

  @@index([certRecordId])
}

// Cert-expiry notifications are computed on the fly from CertRecord rows; this
// table only persists which (cert, priority-bucket) alerts a manager has
// acknowledged, so the bell badge and the Notifications page stay meaningful.
model CertNotificationAck {
  id             String   @id @default(cuid())
  certRecordId   String
  priority       String // bucket acknowledged (LOW | MEDIUM | HIGH | CRITICAL)
  acknowledgedBy String
  acknowledgedAt DateTime @default(now())

  @@unique([certRecordId, priority])
}

// ─── TRAINING ────────────────────────────────────────────────────────────────

model TrainingProgramme {
  id                    String           @id @default(cuid())
  name                  String
  description           String           @default("")
  category              TrainingCategory
  requiredForRoles      StaffRole[]      @relation("ProgrammeRequiredRoles")
  isOneTime             Boolean          @default(true)
  refreshIntervalMonths Int?
  active                Boolean          @default(true)
  createdAt             DateTime         @default(now())
  trainingRecords       TrainingRecord[]
  modules               TrainingModule[]
}

model TrainingRecord {
  id            String             @id @default(cuid())
  staffId       String
  staff         StaffMember        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  programmeId   String?
  programme     TrainingProgramme? @relation(fields: [programmeId], references: [id])
  title         String
  category      TrainingCategory
  delivery      TrainingDelivery
  deliveredBy   String
  completedDate DateTime
  durationHours Float
  outcome       TrainingOutcome
  expiryDate    DateTime?
  notes         String             @default("")
  documentId    String?
  recordedBy    String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([staffId])
}

// A training programme can be broken into ordered modules, each able to hold an
// estimated duration, learning resources (links or uploaded files) and an
// optional assessment. Completion is tracked per staff member, per module.
model TrainingModule {
  id               String                     @id @default(cuid())
  programmeId      String
  programme        TrainingProgramme          @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  title            String
  description      String                     @default("")
  sortOrder        Int                        @default(0)
  estimatedMinutes Int?
  hasAssessment    Boolean                    @default(false)
  passMark         Int?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  resources        TrainingModuleResource[]
  completions      TrainingModuleCompletion[]

  @@index([programmeId])
}

model TrainingModuleResource {
  id         String         @id @default(cuid())
  moduleId   String
  module     TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  kind       ResourceKind   @default(LINK)
  label      String
  url        String
  filename   String?
  fileType   String?
  fileSizeKb Int?
  uploadedBy String         @default("")
  createdAt  DateTime       @default(now())

  @@index([moduleId])
}

model TrainingModuleCompletion {
  id            String         @id @default(cuid())
  moduleId      String
  module        TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  staffId       String
  staff         StaffMember    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  completedDate DateTime
  score         Int?
  passed        Boolean        @default(true)
  notes         String         @default("")
  recordedBy    String         @default("")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([moduleId, staffId])
  @@index([staffId])
}

enum ResourceKind {
  LINK
  FILE
}

enum TrainingCategory {
  INDUCTION
  HEALTH_SAFETY
  ROLE_SPECIFIC
  LEADERSHIP
  COMPLIANCE
  CUSTOMER_SERVICE
  OTHER
}

enum TrainingDelivery {
  IN_PERSON
  ONLINE
  EXTERNAL_COURSE
  SHADOWING
  E_LEARNING
}

enum TrainingOutcome {
  PASS
  FAIL
  ATTENDED
  IN_PROGRESS
  PENDING
}

// ─── ONBOARDING ──────────────────────────────────────────────────────────────
// The new-starter journey. Steps form a configurable checklist (global or
// role-specific); completion is tracked per staff member. Distinct from the
// training library — induction lives here, not as a training programme.
model OnboardingStep {
  id            String                 @id @default(cuid())
  title         String
  description   String                 @default("")
  category      OnboardingCategory     @default(PAPERWORK)
  sortOrder     Int                    @default(0)
  roleId        String? // null = applies to every new starter
  role          StaffRole?             @relation(fields: [roleId], references: [id], onDelete: SetNull)
  dueOffsetDays Int? // due this many days after the staff member's start date
  active        Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  completions   OnboardingCompletion[]

  @@index([roleId])
}

model OnboardingCompletion {
  id            String         @id @default(cuid())
  stepId        String
  step          OnboardingStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  staffId       String
  staff         StaffMember    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  completedDate DateTime
  completedBy   String         @default("")
  notes         String         @default("")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([stepId, staffId])
  @@index([staffId])
}

enum OnboardingCategory {
  PAPERWORK
  VETTING
  TRAINING
  ACCESS
  EQUIPMENT
  REVIEW
  OTHER
}

// ─── AUDIT ───────────────────────────────────────────────────────────────────
// Append-only trail of every change, for maximum auditability.

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String? // User.id of who made the change (null = system)
  actorName String // denormalised so the trail survives user deletion
  action    String // e.g. "staff.created", "absence.logged", "cert.deleted"
  entity    String // "StaffMember" | "AbsenceRecord" | "CertRecord" | …
  entityId  String?
  staffId   String? // when the change concerns a staff member (per-staff trail)
  centerId  String?
  summary   String // human-readable description
  detail    String? // optional extra context
  createdAt DateTime @default(now())

  @@index([staffId])
  @@index([entity])
  @@index([createdAt])
}
