# Copy to .env for local development.
#
# Local dev: point these at a local Postgres (`docker compose up -d`) or a Neon "dev" branch.
# Production (Vercel): the Neon integration sets BOTH of these automatically —
#   you normally don't need to add anything by hand.
#
# DATABASE_URL — pooled connection, used by the app at runtime (serverless-safe).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# DATABASE_URL_UNPOOLED — direct (unpooled) connection, used by Prisma for migrations.
# On Neon this is the "unpooled" string. For a local Postgres it can equal DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# --- Authentication (Auth.js, email + password) ---
# Secret used to sign session cookies. Generate with: npx auth secret
AUTH_SECRET="generate-me"

# --- AI assessment drafting (Vercel AI Gateway) ---
# Powers "Draft hazards with AI". Routed through the Vercel AI Gateway, which
# uses the provider keys (DeepSeek, Google AI Studio, …) configured on your
# Vercel team's AI Gateway. Server-side only.
#
# Auth: on a Vercel deployment this is AUTOMATIC via OIDC (VERCEL_OIDC_TOKEN) —
# you usually don't need to set anything. For local dev (or to be explicit),
# create an AI Gateway key in the Vercel dashboard and set it here:
# AI_GATEWAY_API_KEY="vck_..."
#
# Model used for drafting — any "creator/model" id enabled on your gateway.
# Defaults to google/gemini-2.5-flash. Examples:
#   google/gemini-2.5-flash | google/gemini-3.5-flash | deepseek/deepseek-v3.1
# RISKLY_AI_MODEL="google/gemini-2.5-flash"
