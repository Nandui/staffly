// Riskly — leisure-centre risk assessment schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for the app at runtime; direct/unpooled for migrations.
  // Neon's Vercel integration provides both names automatically.
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// A leisure centre / site. Top-level scoping dimension (one org, many centres).
model Center {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  siteCode     String? // 2-letter code used in assessment references (RA-XX-0001)
  address      String?
  contactName  String?
  contactEmail String?
  phone        String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  areas       Area[]
  assessments RiskAssessment[]

  // Staffly (Centrely Suite) — shares the centre/site dimension.
  staff      StaffMember[]
  staffRoles StaffRole[]
}

// Physical / functional area within a centre (poolside, gym floor, plant room...). Per-centre.
model Area {
  id          String   @id @default(cuid())
  centerId    String
  center      Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments RiskAssessment[]

  @@index([centerId])
}

// Staff role (lifeguard, fitness instructor...). Org-level shared library, reusable across centres.
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments RiskAssessment[]
}

// Activity (pool supervision, chemical handling...). Org-level shared library.
model Activity {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments RiskAssessment[]
}

// Organisational department that owns assessments (Ops, Maintenance, Accounts…).
// Org-level shared library, managed on the Library page.
model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments RiskAssessment[]
}

// The core document. Each assessment is ABOUT one subject — an area, a role
// or an activity (subjectType says which) — at a centre, and is named after it.
model RiskAssessment {
  id                    String    @id @default(cuid())
  reference             String    @unique
  description           String?
  centerId              String
  center                Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  subjectType           String    @default("Area") // Area | Role | Activity
  areaId                String?
  area                  Area?     @relation(fields: [areaId], references: [id])
  roleId                String?
  role                  Role?     @relation(fields: [roleId], references: [id])
  activityId            String?
  activity              Activity? @relation(fields: [activityId], references: [id])
  ownerId               String?
  owner                 User?       @relation("OwnedBy", fields: [ownerId], references: [id])
  departmentId          String?
  department            Department? @relation(fields: [departmentId], references: [id])
  status                String    @default("Draft") // Draft | Active | UnderReview | Archived
  assessorName          String?
  approvedByName        String?
  approvedById          String?
  approvedBy            User?     @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt            DateTime?
  assessmentDate        DateTime  @default(now())
  reviewFrequencyMonths Int       @default(12)
  lastReviewedDate      DateTime?
  nextReviewDate        DateTime
  version               Int       @default(1)
  hazardSeq             Int       @default(0) // high-water mark for hazard seq allocation (never reused)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  hazards        Hazard[]
  reviewLogs     ReviewLog[]
  reviewRequests ReviewRequest[]
  auditLogs      AuditLog[]

  @@index([centerId])
  @@index([areaId])
  @@index([roleId])
  @@index([activityId])
  @@index([ownerId])
  @@index([departmentId])
  @@index([status])
  @@index([nextReviewDate])
}

// Hazard line item: Hazard | Risk Factor | Person at Risk | Consequence |
// Current Controls | Likelihood × Consequence Severity = Overall Risk | Category.
model Hazard {
  id              String         @id @default(cuid())
  assessmentId    String
  assessment      RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  sortOrder       Int            @default(0)
  seq             Int            // permanent per-assessment number for the hazard reference (RA-…-HZ-NNN); never reused
  hazard          String
  riskFactor      String?
  personAtRisk    String?
  consequence     String?
  currentControls String?
  likelihood      Int            @default(1) // 1-5
  severity        Int            @default(1) // 1-5 (consequence severity)
  riskCategory    String         @default("Physical")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([assessmentId, seq])
  @@index([assessmentId])
  @@index([riskCategory])
}

// Audit trail of reviews — supports the monitoring story.
model ReviewLog {
  id             String         @id @default(cuid())
  assessmentId   String
  assessment     RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  reviewedDate   DateTime       @default(now())
  reviewerName   String?
  outcome        String         @default("NoChanges") // NoChanges | Updated | Escalated
  notes          String?
  nextReviewDate DateTime
  createdAt      DateTime       @default(now())

  @@index([assessmentId])
}

// ---- Authentication & users (Auth.js / NextAuth, email + password) ----

// App user. Admins create accounts and assign roles; password is bcrypt-hashed.
model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  image        String?
  passwordHash String?
  role         String   @default("Viewer") // Viewer | Contributor | Reviewer | Assessor | Admin
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedAssessments       RiskAssessment[] @relation("OwnedBy")
  approvedAssessments    RiskAssessment[] @relation("ApprovedBy")
  reviewRequestsMade     ReviewRequest[]  @relation("RequestedBy")
  reviewRequestsResolved ReviewRequest[]  @relation("ResolvedBy")
  auditLogs              AuditLog[]       @relation("AuditActor")

  @@index([role])
}

// A request (raised by a Contributor+) that an assessment be reviewed.
model ReviewRequest {
  id            String         @id @default(cuid())
  assessmentId  String
  assessment    RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User           @relation("RequestedBy", fields: [requestedById], references: [id])
  notes         String
  status        String         @default("Open") // Open | Actioned | Dismissed
  createdAt     DateTime       @default(now())
  resolvedAt    DateTime?
  resolvedById  String?
  resolvedBy    User?          @relation("ResolvedBy", fields: [resolvedById], references: [id])

  @@index([assessmentId])
  @@index([status])
}

// Append-only activity / change log for an assessment (created, edited,
// approved, reviewed, status changed…) — the audit trail.
model AuditLog {
  id            String          @id @default(cuid())
  assessmentId  String?
  assessment    RiskAssessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  assessmentRef String? // denormalised so the trail stays readable if the assessment is deleted
  userId        String?
  user          User?           @relation("AuditActor", fields: [userId], references: [id], onDelete: SetNull)
  userName      String?
  action        String
  detail        String?
  createdAt     DateTime        @default(now())

  @@index([assessmentId])
  @@index([createdAt])
}

// ─── STAFFLY ─────────────────────────────────────────────────────────────────
// HR & people-management module of the Centrely Suite. Shares Center + User
// with Riskly; everything below is Staffly-owned.

model StaffMember {
  id          String      @id @default(cuid())
  centerId    String
  center      Center      @relation(fields: [centerId], references: [id])
  firstName   String
  lastName    String
  email       String
  phone       String      @default("")
  photo       String?
  roleId      String?
  role        StaffRole?  @relation(fields: [roleId], references: [id])
  status      StaffStatus @default(ACTIVE)
  startDate   DateTime
  endDate     DateTime?
  notes       String      @default("")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  absences         AbsenceRecord[]
  performanceNotes PerformanceNote[]
  disciplinary     DisciplinaryRecord[]
  documents        StaffDocument[]
  certifications   CertRecord[]
  trainingRecords  TrainingRecord[]

  @@index([centerId])
  @@index([status])
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  PROBATION
}

model StaffRole {
  id                 String              @id @default(cuid())
  centerId           String?
  center             Center?             @relation(fields: [centerId], references: [id])
  name               String
  active             Boolean             @default(true)
  requiredCertTypes  CertType[]          @relation("RoleRequiredCerts")
  staff              StaffMember[]
  trainingProgrammes TrainingProgramme[] @relation("ProgrammeRequiredRoles")
  createdAt          DateTime            @default(now())
}

// ─── ABSENCE ─────────────────────────────────────────────────────────────────

model AbsenceRecord {
  id                      String      @id @default(cuid())
  staffId                 String
  staff                   StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type                    AbsenceType
  startDate               DateTime
  endDate                 DateTime
  daysCount               Int
  reason                  String      @default("")
  certProvided            Boolean     @default(false)
  approvedBy              String
  returnToWorkNote        String      @default("")
  returnToWorkCompletedAt DateTime?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  @@index([staffId])
}

enum AbsenceType {
  SICK_UNCERTIFIED
  SICK_CERTIFIED
  UNAUTHORISED
  ANNUAL_LEAVE
  PARENTAL_LEAVE
  BEREAVEMENT
  OTHER
}

// ─── PERFORMANCE ─────────────────────────────────────────────────────────────

model PerformanceNote {
  id         String                    @id @default(cuid())
  staffId    String
  staff      StaffMember               @relation(fields: [staffId], references: [id], onDelete: Cascade)
  category   PerformanceNoteCategory
  title      String
  body       String
  visibility PerformanceNoteVisibility @default(MANAGER_ONLY)
  createdBy  String
  noteDate   DateTime
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  @@index([staffId])
}

enum PerformanceNoteCategory {
  POSITIVE
  CONCERN
  FORMAL
  OBJECTIVE
  REVIEW
}

enum PerformanceNoteVisibility {
  MANAGER_ONLY
  SHARED_WITH_STAFF
}

// ─── DISCIPLINARY ─────────────────────────────────────────────────────────────

model DisciplinaryRecord {
  id                String             @id @default(cuid())
  staffId           String
  staff             StaffMember        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  stage             DisciplinaryStage
  status            DisciplinaryStatus @default(OPEN)
  meetingDate       DateTime
  incidentDate      DateTime
  reviewDate        DateTime?
  description       String
  outcome           String
  managedBy         String
  witnessPresent    Boolean            @default(false)
  witnessName       String?
  staffAcknowledged Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([staffId])
  @@index([status])
}

enum DisciplinaryStage {
  VERBAL_WARNING
  WRITTEN_WARNING
  FINAL_WRITTEN_WARNING
  SUSPENSION
  DISMISSAL
}

enum DisciplinaryStatus {
  OPEN
  RESOLVED
  APPEALED
}

// ─── DOCUMENTS ───────────────────────────────────────────────────────────────

model StaffDocument {
  id         String           @id @default(cuid())
  staffId    String
  staff      StaffMember      @relation(fields: [staffId], references: [id], onDelete: Cascade)
  category   DocumentCategory
  name       String
  filename   String
  fileUrl    String // Vercel Blob URL — no base64
  fileSizeKb Int
  fileType   String
  expiryDate DateTime?
  notes      String           @default("")
  uploadedBy String
  uploadedAt DateTime         @default(now())

  @@index([staffId])
}

enum DocumentCategory {
  CONTRACT
  GARDA_VETTING
  RIGHT_TO_WORK
  CERT
  DISCIPLINARY
  TRAINING
  OTHER
}

// ─── CERTIFICATIONS ──────────────────────────────────────────────────────────

model CertType {
  id              String       @id @default(cuid())
  name            String
  issuingBody     String
  validityMonths  Int
  description     String       @default("")
  isBuiltIn       Boolean      @default(false)
  active          Boolean      @default(true)
  certRecords     CertRecord[]
  requiredByRoles StaffRole[]  @relation("RoleRequiredCerts")
  createdAt       DateTime     @default(now())
}

model CertRecord {
  id         String      @id @default(cuid())
  staffId    String
  staff      StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  certTypeId String
  certType   CertType    @relation(fields: [certTypeId], references: [id])
  certNumber String      @default("")
  issueDate  DateTime
  expiryDate DateTime
  documentId String?
  notes      String      @default("")
  recordedBy String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([staffId])
  @@index([expiryDate])
}

// Cert-expiry notifications are computed on the fly from CertRecord rows; this
// table only persists which (cert, priority-bucket) alerts a manager has
// acknowledged, so the bell badge and the Notifications page stay meaningful.
model CertNotificationAck {
  id             String   @id @default(cuid())
  certRecordId   String
  priority       String // bucket acknowledged (LOW | MEDIUM | HIGH | CRITICAL)
  acknowledgedBy String
  acknowledgedAt DateTime @default(now())

  @@unique([certRecordId, priority])
}

// ─── TRAINING ────────────────────────────────────────────────────────────────

model TrainingProgramme {
  id                    String           @id @default(cuid())
  name                  String
  description           String           @default("")
  category              TrainingCategory
  requiredForRoles      StaffRole[]      @relation("ProgrammeRequiredRoles")
  isOneTime             Boolean          @default(true)
  refreshIntervalMonths Int?
  active                Boolean          @default(true)
  createdAt             DateTime         @default(now())
  trainingRecords       TrainingRecord[]
}

model TrainingRecord {
  id            String             @id @default(cuid())
  staffId       String
  staff         StaffMember        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  programmeId   String?
  programme     TrainingProgramme? @relation(fields: [programmeId], references: [id])
  title         String
  category      TrainingCategory
  delivery      TrainingDelivery
  deliveredBy   String
  completedDate DateTime
  durationHours Float
  outcome       TrainingOutcome
  expiryDate    DateTime?
  notes         String             @default("")
  documentId    String?
  recordedBy    String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([staffId])
}

enum TrainingCategory {
  INDUCTION
  HEALTH_SAFETY
  ROLE_SPECIFIC
  LEADERSHIP
  COMPLIANCE
  CUSTOMER_SERVICE
  OTHER
}

enum TrainingDelivery {
  IN_PERSON
  ONLINE
  EXTERNAL_COURSE
  SHADOWING
  E_LEARNING
}

enum TrainingOutcome {
  PASS
  FAIL
  ATTENDED
  IN_PROGRESS
  PENDING
}
